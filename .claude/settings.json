{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/prevent-main-commit.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/prevent-main-edit.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/prevent-generated-edit.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/prevent-main-edit.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/prevent-generated-edit.sh"
          }
        ]
      }
    ]
  }
}
